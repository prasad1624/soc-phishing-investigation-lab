<group name="ssh,finance,critical_alerts,">

  <rule id="100100" level="7">
    <if_sid>5710</if_sid>
    <description>SSH authentication failure detected</description>
    <group>ssh,authentication,failed</group>
  </rule>

  <rule id="100101" level="5">
    <if_sid>5715</if_sid>
    <description>SSH authentication success</description>
    <group>ssh,authentication,success</group>
  </rule>

  <rule id="100200" level="12">
    <if_sid>80700</if_sid>
    <field name="audit.key">finance_access</field>
    <description>Access to Tier-0 finance directory detected</description>
    <group>file_access,finance,sensitive_data</group>
  </rule>

  <rule id="100300" level="10">
    <if_sid>5402, 5403</if_sid>
    <description>Successful privilege escalation via sudo detected</description>
    <group>sudo,privilege_escalation</group>
  </rule>

  <rule id="100400" level="13">
    <if_sid>80700</if_sid>
    <field name="audit.key">finance_backup</field>
    <description>Sensitive finance data activity detected in backup directory</description>
    <group>data_movement,backup,finance</group>
  </rule>

  <rule id="100999" level="15" frequency="2" timeframe="300">
    <if_matched_sid>100101</if_matched_sid>
    <if_matched_sid>100200</if_matched_sid>
    <if_matched_sid>100300</if_matched_sid>
    <if_matched_sid>100400</if_matched_sid>
    <description>CRITICAL: Multi-stage attack: SSH Login, Sudo, and Finance Access detected</description>
    <group>critical,correlated_attack,finance_tier0</group>
  </rule>

</group>